local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local DataModule
local success, err = pcall(function()
    DataModule = require(LocalPlayer.PlayerScripts.ClientEngine.GameplayModule.DataModule)
end)

if not success then
    warn("Failed to load DataModule: " .. tostring(err))
    return
end

local PredictionFolder = workspace:FindFirstChild("Ball_Trajectory") or Instance.new("Folder")
if not PredictionFolder.Parent then
    PredictionFolder.Name = "Ball_Trajectory"
    PredictionFolder.Parent = workspace
end

local dots = {}
local MAX_DOTS = 200

for i = 1, MAX_DOTS do
    local dot = PredictionFolder:FindFirstChild("Dot"..i) or Instance.new("Part")
    dot.Name = "Dot"..i
    dot.Shape = Enum.PartType.Ball
    dot.Size = Vector3.new(0.15, 0.15, 0.15)
    dot.Transparency = 1
    dot.Color = Color3.fromRGB(255, 170, 0)
    dot.Anchored = true
    dot.CanCollide = false
    dot.CanTouch = false
    dot.CanQuery = false
    dot.Parent = PredictionFolder
    dots[i] = dot
end

local function GetVelocity(power, angle, putting)
    local v4 = math.floor(power + 0.5)
    local v52 = math.floor(angle + 0.5)
    if putting then
        return Vector3.new(math.cos(math.rad(v52)) * (v4 * 0.45 + 5), 0, 0)
    else
        local v72 = math.clamp((v4 * 31.35) ^ 0.5714285714285714 + 3, 10, 1/0)
        return Vector3.new(math.cos(math.rad(v52)) * v72, -math.sin(math.rad(v52)) * v72, 0)
    end
end

local function UpdateTrajectory()
    local holeData = DataModule.CurrentHoleData
    local globalData = DataModule.GlobalData
    
    if not holeData or not globalData or not globalData.Ball then return end
    
    local isAiming = holeData.BallInRest and not holeData.WaitingForServer and holeData.HoleActive
    if not isAiming then
        if holeData.BallInRest then
            for i = 1, MAX_DOTS do dots[i].Transparency = 1 end
        end
        return
    end

    local startPos = globalData.Ball.Position
    local vel = GetVelocity(holeData.CurrentPower, holeData.CurrentAngle, holeData.Putting)
    local g = Vector3.new(0, -80, 0)
    local dt = 1/30
    
    local currentPos = startPos
    local currentVel = vel
    
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {workspace.Balls, workspace.Characters, PredictionFolder}

    local bounceCount = 0
    local maxBounces = 3
    local stopIdx = MAX_DOTS

    for i = 1, MAX_DOTS do
        dots[i].Position = currentPos
        dots[i].Transparency = 0.2
        
        local stepVel = currentVel * dt + 0.5 * g * dt * dt
        local result = workspace:Raycast(currentPos, stepVel, rayParams)
        
        if result then
            if bounceCount < maxBounces then
                bounceCount = bounceCount + 1
                
                local normal = result.Normal
                currentVel = currentVel - 2 * currentVel:Dot(normal) * normal
                
                currentVel = Vector3.new(currentVel.X, currentVel.Y, 0)
                
                local bounceFactor = 0.5
                if result.Instance.Name == "Green" then
                    bounceFactor = 0.2
                elseif result.Instance.Name == "Sand" then
                    currentVel = Vector3.new(0,0,0)
                    stopIdx = i
                    break
                end
                
                currentVel = currentVel * bounceFactor
                
                if currentVel.Magnitude < 2 then
                    stopIdx = i
                    break
                end
                
                currentPos = result.Position + result.Normal * 0.01
            else
                stopIdx = i
                break
            end
        else
            currentPos = currentPos + stepVel
            currentVel = currentVel + g * dt
        end
        
        if currentPos.Y < -50 then
            stopIdx = i
            break
        end
    end
    
    for i = stopIdx + 1, MAX_DOTS do
        dots[i].Transparency = 1
    end
end

RunService.RenderStepped:Connect(UpdateTrajectory)